<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Color Tokens -->
    <SolidColorBrush x:Key="WindowBackground"    Color="#030B1A"/>
    <SolidColorBrush x:Key="SurfaceBackground"   Color="#050C1A"/>
    <SolidColorBrush x:Key="SurfaceHover"        Color="#0A1628"/>
    <SolidColorBrush x:Key="AccentIndigo"        Color="#4F46E5"/>
    <SolidColorBrush x:Key="AccentIndigoHover"   Color="#6366F1"/>
    <SolidColorBrush x:Key="AccentPink"          Color="#DB2777"/>
    <SolidColorBrush x:Key="AccentPinkHover"     Color="#EC4899"/>
    <SolidColorBrush x:Key="TextPrimary"         Color="#EDF2FF"/>
    <SolidColorBrush x:Key="TextSecondary"       Color="#A8B7FF"/>
    <SolidColorBrush x:Key="TextMuted"           Color="#818CF8"/>
    <SolidColorBrush x:Key="ButtonDark"          Color="#1E274D"/>
    <SolidColorBrush x:Key="ButtonDarkHover"     Color="#2D3A6B"/>
    <SolidColorBrush x:Key="BorderSubtle"        Color="#1E293B"/>
    <SolidColorBrush x:Key="ScrollbarThumb"      Color="#334155"/>
    <SolidColorBrush x:Key="ScrollbarTrack"      Color="#0F172A"/>
    <SolidColorBrush x:Key="GradientStart"       Color="#4F46E5"/>
    <SolidColorBrush x:Key="GradientEnd"         Color="#DB2777"/>
    <SolidColorBrush x:Key="WindowBorder"        Color="#1E293B"/>
    <SolidColorBrush x:Key="FocusBorder"         Color="#6366F1"/>
    <SolidColorBrush x:Key="ErrorText"           Color="#F87171"/>
    <SolidColorBrush x:Key="SuccessText"         Color="#34D399"/>

</ResourceDictionary>

<Window x:Class="LuminaLex.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LuminaLex.Converters"
        Title="Lumina Lex"
        Width="730" Height="590"
        MinWidth="500" MinHeight="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToThemeIconConverter x:Key="BoolToThemeIcon"/>
    </Window.Resources>

    <!-- Outer container: drop shadow + rounded corners -->
    <Border x:Name="RootBorder" CornerRadius="12" Margin="16"
            Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource WindowBorder}"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <!-- Clip content to rounded corners -->
        <Border.Clip>
            <RectangleGeometry RadiusX="12" RadiusY="12">
                <RectangleGeometry.Rect>
                    <MultiBinding Converter="{x:Static converters:RectConverter.Instance}">
                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualHeight"/>
                    </MultiBinding>
                </RectangleGeometry.Rect>
            </RectangleGeometry>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header gradient line -->
                <RowDefinition Height="Auto"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>      <!-- Content -->
                <RowDefinition Height="Auto"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ── Header gradient line ──────────────────────────── -->
            <Rectangle Grid.Row="0" Height="3">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4F46E5" Offset="0"/>
                        <GradientStop Color="#DB2777" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Title bar (draggable) ─────────────────────────── -->
            <Grid Grid.Row="1" Margin="24,16,24,8" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon -->
                <TextBlock Grid.Column="0" Text="⬢"
                           FontSize="28" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Title + subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Lumina Lex"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               FontFamily="Segoe UI Variable Display Semib, Segoe UI, sans-serif"/>
                    <TextBlock Text="Moteur linguistique · Responses API · DeepL v2"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Settings button -->
                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Content="⚙" FontSize="16"
                        ToolTip="Paramètres"
                        Command="{Binding OpenSettingsCommand}"
                        Margin="4,0"/>

                <!-- Theme toggle (pill switch) -->
                <Button Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Changer de thème"
                        Margin="4,0">
                    <Grid Width="48" Height="24">
                        <!-- Track -->
                        <Border x:Name="ToggleTrack"
                                CornerRadius="12"
                                Background="{DynamicResource ButtonDark}"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="1"/>
                        <!-- Thumb -->
                        <Border x:Name="ToggleThumb"
                                Width="20" Height="20"
                                CornerRadius="10"
                                Background="{DynamicResource AccentIndigo}"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0">
                            <TextBlock Text="{Binding IsDarkTheme, Converter={StaticResource BoolToThemeIcon}}"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Close button -->
                <Button Grid.Column="4"
                        Style="{StaticResource CloseButton}"
                        Content="✕" FontSize="14" FontWeight="Bold"
                        ToolTip="Fermer"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- ── Main content ──────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="24,8,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Input label -->
                    <RowDefinition Height="2*"/>     <!-- Input text -->
                    <RowDefinition Height="Auto"/>   <!-- Buttons -->
                    <RowDefinition Height="Auto"/>   <!-- Output label -->
                    <RowDefinition Height="2*"/>     <!-- Output text -->
                </Grid.RowDefinitions>

                <!-- Input label -->
                <TextBlock Grid.Row="0" Text="TEXTE SOURCE"
                           Style="{StaticResource SectionLabel}"/>

                <!-- Input text box -->
                <TextBox Grid.Row="1"
                         Style="{StaticResource StyledTextBox}"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <!-- Action buttons -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PrimaryButton}"
                            Content="⚡  Corriger (Turbo)"
                            Height="44"
                            Command="{Binding CorrectCommand}"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource PinkButton}"
                            Content="🌐  Traduire"
                            Height="44"
                            Command="{Binding TranslateCommand}"/>

                    <Button Grid.Column="4"
                            Style="{StaticResource SecondaryButton}"
                            Content="Effacer"
                            Height="44" MinWidth="120"
                            Command="{Binding ClearCommand}"/>
                </Grid>

                <!-- Output label -->
                <TextBlock Grid.Row="3" Text="RÉSULTAT"
                           Style="{StaticResource SectionLabel}"/>

                <!-- Output text box -->
                <TextBox Grid.Row="4"
                         Style="{StaticResource StyledTextBox}"
                         Text="{Binding OutputText, Mode=OneWay}"
                         IsReadOnly="True"/>
            </Grid>

            <!-- ── Status bar ────────────────────────────────────── -->
            <Grid Grid.Row="3" Margin="24,0,24,16">
                <!-- Progress bar (visible when processing) -->
                <ProgressBar Style="{StaticResource AccentProgressBar}"
                             VerticalAlignment="Top"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                             Margin="0,0,0,8"/>

                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource StatusLabel}"
                           Margin="0,12,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>

<Window x:Class="LuminaLex.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LuminaLex.Converters"
        xmlns:models="clr-namespace:LuminaLex.Models"
        Title="Lumina Lex"
        Icon="/app.ico"
        Width="730" Height="590"
        MinWidth="500" MinHeight="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToThemeIconConverter x:Key="BoolToThemeIcon"/>
        <converters:DiffForegroundConverter x:Key="DiffFg"/>
        <converters:DiffDecorationConverter x:Key="DiffDeco"/>
        <converters:DiffBackgroundConverter x:Key="DiffBg"/>
    </Window.Resources>

    <!-- Outer container: drop shadow + rounded corners -->
    <Border x:Name="RootBorder" CornerRadius="12" Margin="16"
            Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource WindowBorder}"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <!-- Clip content to rounded corners -->
        <Border.Clip>
            <RectangleGeometry RadiusX="12" RadiusY="12">
                <RectangleGeometry.Rect>
                    <MultiBinding Converter="{x:Static converters:RectConverter.Instance}">
                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualHeight"/>
                    </MultiBinding>
                </RectangleGeometry.Rect>
            </RectangleGeometry>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header gradient line -->
                <RowDefinition Height="Auto"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>      <!-- Content -->
                <RowDefinition Height="Auto"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ── Header gradient line ──────────────────────────── -->
            <Rectangle Grid.Row="0" Height="4">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4F46E5" Offset="0"/>
                        <GradientStop Color="#DB2777" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Title bar (draggable) ─────────────────────────── -->
            <Grid Grid.Row="1" Margin="24,16,24,8" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon -->
                <TextBlock Grid.Column="0" Text="⬢"
                           FontSize="28" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B5CF6" Offset="0"/>
                            <GradientStop Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Title + subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Lumina Lex"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               FontFamily="Segoe UI Variable Display Semib, Segoe UI, sans-serif"/>
                    <TextBlock Text="Moteur linguistique · Responses API · DeepL v2"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Settings button -->
                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Content="⚙" FontSize="16"
                        ToolTip="Paramètres"
                        Command="{Binding OpenSettingsCommand}"
                        Margin="4,0"/>

                <!-- Theme toggle -->
                <Button Grid.Column="3"
                        Style="{StaticResource IconButton}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Changer de thème"
                        Margin="4,0"
                        Width="36" Height="36">
                    <TextBlock Text="{Binding IsDarkTheme, Converter={StaticResource BoolToThemeIcon}}"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Debug toggle -->
                <Button Grid.Column="4"
                        Style="{StaticResource IconButton}"
                        Command="{Binding ToggleDebugCommand}"
                        ToolTip="Terminal de debug"
                        Margin="4,0"
                        Width="36" Height="36">
                    <TextBlock Text="🐛" FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Close button -->
                <Button Grid.Column="5"
                        Style="{StaticResource CloseButton}"
                        Content="✕" FontSize="14" FontWeight="Bold"
                        ToolTip="Fermer"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- ── Main content ──────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="24,8,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Input label -->
                    <RowDefinition Height="2*"/>     <!-- Input text -->
                    <RowDefinition Height="Auto"/>   <!-- Buttons -->
                    <RowDefinition Height="Auto"/>   <!-- Output label -->
                    <RowDefinition Height="2*"/>     <!-- Output text -->
                </Grid.RowDefinitions>

                <!-- Input label -->
                <TextBlock Grid.Row="0" Text="TEXTE SOURCE"
                           Style="{StaticResource SectionLabel}"/>

                <!-- Input text box with copy/paste buttons -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,6,8,0">
                        <Button Style="{StaticResource IconButton}"
                                Content="📋" FontSize="12"
                                ToolTip="Coller"
                                Width="28" Height="28"
                                Command="{Binding PasteInputCommand}"
                                Opacity="0.6"/>
                        <Button Style="{StaticResource IconButton}"
                                Content="📄" FontSize="12"
                                ToolTip="Copier"
                                Width="28" Height="28"
                                Command="{Binding CopyInputCommand}"
                                Opacity="0.6"/>
                    </StackPanel>
                </Grid>

                <!-- Action buttons -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PrimaryButton}"
                            Content="⚡  Corriger (Turbo)"
                            Height="44"
                            Command="{Binding CorrectCommand}"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource PinkButton}"
                            Content="🌐  Traduire"
                            Height="44"
                            Command="{Binding TranslateCommand}"/>

                    <Button Grid.Column="4"
                            Style="{StaticResource SecondaryButton}"
                            Content="Effacer"
                            Height="44" MinWidth="120"
                            Command="{Binding ClearCommand}"/>
                </Grid>

                <!-- Output label -->
                <TextBlock Grid.Row="3" Text="RÉSULTAT"
                           Style="{StaticResource SectionLabel}"/>

                <!-- Output area -->
                <Grid Grid.Row="4">
                    <!-- Plain output (translation) -->
                    <TextBox Style="{StaticResource StyledTextBox}"
                             Text="{Binding OutputText, Mode=OneWay}"
                             IsReadOnly="True"
                             Visibility="{Binding ShowDiff, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

                    <!-- Colored diff output (correction) -->
                    <Border Background="{DynamicResource SurfaceBackground}"
                            BorderBrush="{DynamicResource BorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10"
                            Visibility="{Binding ShowDiff, Converter={StaticResource BoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding DiffSegments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DiffSegment}">
                                        <Border Background="{Binding Type, Converter={StaticResource DiffBg}}"
                                                CornerRadius="3"
                                                Padding="2,1"
                                                Margin="1,2">
                                            <TextBlock Text="{Binding Text}"
                                                       Foreground="{Binding Type, Converter={StaticResource DiffFg}}"
                                                       TextDecorations="{Binding Type, Converter={StaticResource DiffDeco}}"
                                                       FontSize="14"
                                                       FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Copy output button -->
                    <Button Style="{StaticResource IconButton}"
                            Content="📄" FontSize="12"
                            ToolTip="Copier le résultat"
                            Width="28" Height="28"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,6,8,0"
                            Command="{Binding CopyOutputCommand}"
                            Opacity="0.6"/>
                </Grid>
            </Grid>

            <!-- ── Status bar ────────────────────────────────────── -->
            <StackPanel Grid.Row="3" Margin="24,0,24,16">
                <Rectangle Height="1" Fill="{DynamicResource BorderSubtle}" Opacity="0.4" Margin="0,0,0,10"/>
                <Grid>
                    <ProgressBar Style="{StaticResource AccentProgressBar}"
                                 VerticalAlignment="Top"
                                 Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                                 Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource StatusLabel}"
                               Margin="0,12,0,0"/>
                </Grid>

                <!-- ── Debug Panel ─────────────────────────────── -->
                <Border Visibility="{Binding IsDebugVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource SurfaceBackground}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,12,0,0"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="140"/>
                        </Grid.RowDefinitions>

                        <!-- Debug header -->
                        <Grid Grid.Row="0" Margin="10,6,6,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🐛 DEBUG"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Code, Consolas, monospace"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding ClearDebugCommand}"
                                    ToolTip="Effacer les logs"
                                    Width="24" Height="24"
                                    Content="✕" FontSize="10"/>
                        </Grid>

                        <!-- Debug log listbox -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding DebugEntries}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextSecondary}"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="10.5"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,2"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ── Close Confirmation Overlay ─────────────────────── -->
            <Border x:Name="CloseConfirmOverlay" Grid.RowSpan="4"
                    Background="{DynamicResource OverlayBackground}"
                    Visibility="Collapsed">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{DynamicResource DialogSurface}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="36,32"
                        MinWidth="340" MaxWidth="400">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.5" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Warning icon -->
                        <Border Width="56" Height="56" CornerRadius="28"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#DC2626" Offset="0"/>
                                    <GradientStop Color="#DB2777" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✕" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="Quitter Lumina Lex ?"
                                   FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontFamily="Segoe UI Variable Display Semib, Segoe UI, sans-serif"
                                   Margin="0,0,0,8"/>

                        <!-- Description -->
                        <TextBlock TextAlignment="Center" LineHeight="20"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="13" HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif"
                                   Margin="0,0,0,28">
                            <Run Text="L'application sera fermée et les raccourcis"/>
                            <LineBreak/>
                            <Run Text="globaux seront désactivés."/>
                        </TextBlock>

                        <!-- Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="Annuler" Height="40"
                                    Click="CloseConfirm_Cancel"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource DangerButton}"
                                    Content="Quitter" Height="40"
                                    Click="CloseConfirm_Quit"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
